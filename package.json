{
  "name": "flexi-modal",
  "version": "0.1.0",
  "description": "Accessible, stackable modal Web Component built with Lit",
  "type": "module",
  "main": "./dist/flexi-modal.umd.js",
  "module": "./dist/flexi-modal.es.js",
  "types": "./dist/flexi-modal.d.ts",
  "exports": {
    ".": {
      "import": "./dist/flexi-modal.es.js",
      "require": "./dist/flexi-modal.umd.js",
      "types": "./dist/flexi-modal.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lit": "^3.2.0"
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@open-wc/testing-helpers": "^3.0.0",
    "happy-dom": "^20.9.0",
    "@playwright/test": "^1.40.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
